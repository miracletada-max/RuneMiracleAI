function RuneStone({ rune, index, isSelected, isRevealed, onClick, disabled }) {
  return (
    <div
      className={`rune-stone ${isSelected ? "selected" : ""} ${isRevealed ? "revealed" : ""} ${disabled && !isSelected ? "disabled" : ""}`}
