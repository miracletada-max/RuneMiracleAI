            <div className="header-eye">🔮</div>
            <h1 className="header-title">RUNE ORACLE</h1>
            <p className="header-sub">古代ルーン文字の神託</p>
            <div className="divider" />
          </div>

          {/* INTRO */}
          {step === "intro" && (
            <div className="card">
              <p className="intro-text">
                古代北欧の神々が刻んだルーン文字が、<br />
                あなたの問いに答えます。<br /><br />
                心を静め、問いかけを定め、<br />
                石の中から一つを選んでください。<br />
                ルーンはあなたの魂の声を聴いています。
              </p>
              <button className="btn-primary" onClick={() => setStep("question")}>
                ✦ 占いを始める ✦
              </button>
            </div>
          )}

          {/* QUESTION */}
          {step === "question" && (
            <div className="card">
              <h2 className="card-title">✦ 何を占いますか？ ✦</h2>
              <div className="question-grid">
                {QUESTIONS.slice(0, 5).map((q) => (
                  <button key={q} className="question-btn" onClick={() => handleSelectQuestion(q)}>
                    {q}
                  </button>
                ))}
                <button className="question-btn" onClick={() => handleSelectQuestion("自由に入力する...")}>
                  ✍ 自由に入力する
                </button>
              </div>
              {question === "custom" && (
                <div className="custom-area">
                  <textarea
                    className="custom-input"
                    rows={3}
                    placeholder="あなたの問いを入力してください..."
                    value={customQuestion}
                    onChange={(e) => setCustomQuestion(e.target.value)}
                  />
                  <button className="btn-primary" onClick={handleCustomSubmit}>
                    ✦ 石を選ぶ ✦
                  </button>
                </div>
              )}
            </div>
          )}

          {/* STONES */}
          {(step === "stones" || step === "reading") && shuffledRunes.length > 0 && (
            <div className="card">
              <div className="selected-question">
                「{question === "custom" ? customQuestion : question}」
              </div>
              <br />
              <p className="stones-intro">
                石に手を近づけ、引き寄せられる一つを選んでください。<br />
                直感を信じてください。
              </p>
              <div className="stone-grid">
                {shuffledRunes.map((rune, i) => (
                  <RuneStone
                    key={rune.name}
                    rune={rune}
                    index={i}
                    isSelected={selectedIndex === i}
                    isRevealed={selectedIndex === i}
                    onClick={handleSelectRune}
                    disabled={selectedRune !== null && selectedIndex !== i}
                  />
                ))}
              </div>

              {step === "reading" && (
                <div className="loading-area">
                  <div className="crystal-ball">🔮</div>
                  {selectedRune && (
                    <div
                      className="loading-rune"
                      style={{ "--rc": selectedRune.color }}
                    >
                      {selectedRune.symbol}
                    </div>
                  )}
                  <p className="loading-text">ルーンの声を聴いています…</p>
                </div>
              )}
            </div>
          )}

          {/* RESULT */}
          {step === "result" && selectedRune && (
            <div className="card" ref={readingRef} style={{ "--rc": selectedRune.color }}>
              <div className="result-header">
                <div className="result-rune-symbol">{selectedRune.symbol}</div>
                <div className="result-rune-name">{selectedRune.name}</div>
                <div className="result-rune-meaning">{selectedRune.meaning} ｜ {selectedRune.element}</div>
                <div className="result-divider" />
              </div>

              <div className="reading-text">{reading}</div>

              <div className="share-section">
                <p className="share-text">✦ シェアして友人にも届けよう ✦</p>
                <div className="share-buttons">
                  <button
                    className="share-btn twitter"
                    onClick={() => {
                      const q = question === "custom" ? customQuestion : question;
                      const text = `🔮 ルーン占い結果\n「${q}」\n選ばれたルーン：${selectedRune.symbol} ${selectedRune.name}\n#ルーン占い #RUNEORACLE`;
                      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`);
                    }}
                  >
                    ✕ Xでシェア
                  </button>
                  <button
                    className="share-btn line"
                    onClick={() => {
                      const q = question === "custom" ? customQuestion : question;
                      const text = `🔮 ルーン占い「${q}」→ ${selectedRune.symbol} ${selectedRune.name}`;
                      window.open(`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(window.location.href)}&text=${encodeURIComponent(text)}`);
                    }}
                  >
                    LINE
                  </button>
                  <button
                    className="share-btn instagram"
                    onClick={() => alert("スクリーンショットを撮ってInstagramにシェアしてね✨ #ルーン占い")}
                  >
                    📸 Instagram
                  </button>
                </div>
              </div>

              <button className="btn-reset" onClick={handleReset}>
                ↺ もう一度占う
              </button>
            </div>
          )}

          <div className="footer">
            RUNE ORACLE ✦ Ancient Nordic Wisdom ✦ AI Powered
          </div>
        </div>
      </div>
    </>
  );
}
